[Unit]
Description=Kids English Speaking Agent
After=network.target mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/kids-english/backend
EnvironmentFile=/opt/kids-english/.env
ExecStart=/opt/kids-english/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8003
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
